package(default_visibility = ["//visibility:public"])

load("@rules_perl//perl:perl.bzl", "perl_binary", "perl_library")
load("@rules_shell//shell:sh_binary.bzl", "sh_binary")
load("@bazel_lib//lib:run_binary.bzl", "run_binary")
load("@bazel_lib//lib:write_source_files.bzl", "write_source_file")
load("@doxygen//:doxygen.bzl", "doxygen")

# $(EXTRA) in the Makefile
filegroup(
  name = "extra",
  srcs = [
    "acronyms.txt",
    "aspell.en.pws",
  ] + glob([
    "*.pm",
    "*cap",
  ]),
)

# $(DEPS) in the Makefile
filegroup(
  name = "deps",
  srcs = [
    "//SAI/inc:all_headers",
    "//SAI/experimental:all_headers",
    # TODO BL: This target doesn't exist in 202405
    # "//SAI/custom:all_headers",
  ],
)

filegroup(
  name = "all_headers",
  srcs = glob(["*.h"]) + [":saimetadata.h"],
)

filegroup(
  name = "all_srcs",
  srcs = glob(["**/*.h", "**/*.c"]),
)

filegroup(
  name = "constheaders",
  srcs = ["saimetadatatypes.h","saimetadatalogger.h", "saimetadatautils.h", "saiserialize.h"],
)

