perl_library(
  name = "perl_lib",
  srcs = [
    "utils.pm",
    "xmlutils.pm",
    "style.pm",
    "cap.pm",
    "serialize.pm",
    "test.pm",
  ],
)

perl_binary(
  name = "parse",
  main = "parse.pl",
  srcs = [
    "parse.pl",
  ],
  deps = [
    ":perl_lib",
    "@rules_perl//perl/runfiles",
  ],
  data = [
    # $(XMLDEPS)
    # TODO BL: There are a lot of errors like this one, we should figure out what's up:
    #   ERROR: invalid object type SAI_OBJECT_TYPE_TAM_COUNTER_SUBSCRIPTION extracted from bulk definition: sai_bulk_object_remove_fn                      remove_tam_counter_subscriptions
    ":doxygen",
    # $(CONSTHEADERS)
    ":constheaders",
    # $(EXTRA)
    ":extra",
    # $(DEPS)
    ":deps",
    # TODO BL: we may not need saiattrversion in this brnach
    # saiattrversion.h
    # ":saiattrversion",
  ],
)

run_binary(
  name = "run_parse",
  tool = ":parse",
  args = ["-d"],
  outs = [
    ":saimetadatatest.c",
    ":saimetadata.c",
    ":saimetadata.h",
    ":saiswig.i",
  ],
  env = {
    "OUTFILEMARKER": "$(execpath :saimetadatatest.c)",
  },
)

doxygen(
  name = "doxygen",
  doxyfile_template = "Doxyfile.bazel",
  outs = [
    "xml",
  ],
  srcs = [
    ":constheaders",
    # $(DEPS)
    ":deps",
  ],
)
